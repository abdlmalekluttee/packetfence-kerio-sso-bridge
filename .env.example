# ---- HTTP Basic auth PacketFence presents to the JSON-RPC endpoint (POST /) ----
BRIDGE_USER=packetfence
BRIDGE_PASS=change-me

# ---- HTTP Basic auth for the management GUI (browser login) ----
ADMIN_USER=admin
ADMIN_PASS=change-me-too

# ---- Listener / TLS ----
LISTEN_ADDR=0.0.0.0
LISTEN_PORT=9090
CERT_FILE=/certs/bridge.crt
KEY_FILE=/certs/bridge.key

# Kerio firewalls are NOT configured here anymore -- add them in the GUI.
# (Stored in ./data/kerios.json so they survive restarts.)
